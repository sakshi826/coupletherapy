  "needs": {
    "Emotional support": {
      "label": "情感支持",
      "prompt": "您現在真正需要什麼樣的幫助？",
      "hints": {
        "0": "我只是需要有人…",
        "1": "如果……那就太好了。",
        "2": "我真正想要的是…"
      }
    },
    "Space / time for myself": {
      "label": "屬於我自己的空間/時間",
      "prompt": "對你來說，擁有那樣的空間會是什麼樣子？",
      "hints": {
        "0": "我會利用那段時間…",
        "1": "太空會讓我…",
        "2": "我需要空間…"
      }
    },
    "Clear communication": {
      "label": "清晰的溝通",
      "prompt": "你認為更清晰的溝通應該是什麼樣的？",
      "hints": {
        "0": "我真希望我能說…",
        "1": "如果他們真的聽進去了，我會告訴他們…",
        "2": "當……時，溝通會變得很困難。"
      }
    },
    "Reassurance": {
      "label": "放心",
      "prompt": "什麼樣的安慰才能讓人感到真正有意義？",
      "hints": {
        "0": "我需要聽到這個…",
        "1": "知道這一點會讓我安心…",
        "2": "我一直擔心…"
      }
    },
    "Understanding": {
      "label": "理解",
      "prompt": "真正被理解的感覺會是什麼樣的呢？",
      "hints": {
        "0": "我希望人們都知道這一點…",
        "1": "我內心真正的感受是…",
        "2": "沒人看到我…"
      }
    },
    "Stability": {
      "label": "穩定",
      "prompt": "你現在覺得生活中穩定是什麼樣的？",
      "hints": {
        "0": "我需要一些能讓我感到…的東西。",
        "1": "能讓我腳踏實地的，是…",
        "2": "穩定意味著…"
      }
    },
    "Honesty": {
      "label": "誠實",
      "prompt": "在你的情況下，怎樣才算更誠實？",
      "hints": {
        "0": "我必須面對的真相是…",
        "1": "我想坦誠地說…",
        "2": "實際情況是…"
      }
    },
    "Respect": {
      "label": "尊重",
      "prompt": "你現在認為尊重是什麼樣的？",
      "hints": {
        "0": "我應該受到應有的待遇…",
        "1": "尊重應該體現在…",
        "2": "我需要人們…"
      }
    },
    "Clarity about relationship": {
      "label": "對關係的清晰認識",
      "prompt": "哪種類型的清晰說明對您最有幫助？",
      "hints": {
        "0": "我需要知道是否…",
        "1": "讓我困惑的是…",
        "2": "我希望我們能明確一點…"
      }
    },
    "default": {
      "prompt": "實際情況會是怎樣的？",
      "hints": {
        "0": "我首先想到的是…",
        "1": "我現在感覺…",
        "2": "如果我對自己誠實的話…"
      }
    }
  },
