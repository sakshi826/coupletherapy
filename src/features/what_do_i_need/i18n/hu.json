  "needs": {
    "Emotional support": {
      "label": "Érzelmi támogatás",
      "prompt": "Milyen támogatás segítene neked most ténylegesen?",
      "hints": [
        "Csak valakire van szükségem, aki...",
        "Segítene, ha...",
        "Amit igazán akarok, az az..."
      ]
    },
    "Space / time for myself": {
      "label": "Tér / idő magamnak",
      "prompt": "Milyen lenne számodra, ha ez a hely lenne?",
      "hints": [
        "Ezt az időt arra használnám, hogy...",
        "Az űr engedne...",
        "Szükségem van helyre, hogy..."
      ]
    },
    "Clear communication": {
      "label": "Világos kommunikáció",
      "prompt": "Milyen lenne nálad tisztább kommunikáció?",
      "hints": [
        "Bárcsak mondhatnám...",
        "Ha tényleg hallgatnának, elmondanám nekik...",
        "Nehéz a kommunikáció, amikor..."
      ]
    },
    "Reassurance": {
      "label": "Megnyugtatás",
      "prompt": "Milyen megnyugtatás érhetné meg jelentőségteljesnek?",
      "hints": [
        "Hallanom, hogy...",
        "Megnyugtatna, ha tudnám...",
        "Folyton aggódom, hogy..."
      ]
    },
    "Understanding": {
      "label": "Megértés",
      "prompt": "Milyen lenne igazán megértettnek érezni?",
      "hints": [
        "Bárcsak tudnák az embereket, hogy...",
        "Amit igazán érzek, az az...",
        "Senki sem látja, hogy én..."
      ]
    },
    "Stability": {
      "label": "Stabilitás",
      "prompt": "Milyen lenne a stabilitás az életedben most?",
      "hints": [
        "Szükségem van arra, hogy olyan dolgok érezzék...",
        "Ami a földhöz kötne, az az...",
        "A stabilitás azt jelenti..."
      ]
    },
    "Honesty": {
      "label": "Őszinteség",
      "prompt": "Milyen lenne az őszinteség a te helyzetedben?",
      "hints": [
        "Az igazság, amit szembe kell néznem, az...",
        "Őszinte akarok lenni...",
        "Ami igazán történik, az..."
      ]
    },
    "Respect": {
      "label": "Tisztelet",
      "prompt": "Milyen a tisztelet most számodra?",
      "hints": [
        "Megérdemlem, hogy bánjanak...",
        "A tisztelet úgy nézne ki, hogy...",
        "Szükségem van emberekre, akiket..."
      ]
    },
    "Clarity about relationship": {
      "label": "Tiszta a kapcsolat",
      "prompt": "Milyen tisztaság segítene neked a legtöbbet?",
      "hints": [
        "Tudnom kell, hogy...",
        "Ami összezavar, az az...",
        "Azt akarom, hogy tisztázzuk magunkat..."
      ]
    },
    "default": {
      "prompt": "Milyen lenne ez egy valódi helyzetben?",
      "hints": [
        "Ami eszembe jut, az az...",
        "Most úgy érzem...",
        "Ha őszinte vagyok magammal..."
      ]
    }
