  "needs": {
    "Emotional support": {
      "label": "情感支持",
      "prompt": "您现在真正需要什么样的帮助？",
      "hints": [
        "我只是需要有人……",
        "如果……那就太好了。",
        "我真正想要的是……"
      ]
    },
    "Space / time for myself": {
      "label": "属于我自己的空间/时间",
      "prompt": "对你来说，拥有那样的空间会是什么样子？",
      "hints": [
        "我会利用那段时间……",
        "太空会让我……",
        "我需要空间……"
      ]
    },
    "Clear communication": {
      "label": "清晰的沟通",
      "prompt": "你认为更清晰的沟通应该是什么样的？",
      "hints": [
        "我真希望我能说……",
        "如果他们真的听进去了，我会告诉他们……",
        "当……时，沟通会变得很困难。"
      ]
    },
    "Reassurance": {
      "label": "放心",
      "prompt": "什么样的安慰才能让人感到真正有意义？",
      "hints": [
        "我需要听到这个……",
        "知道这一点会让我安心……",
        "我一直担心……"
      ]
    },
    "Understanding": {
      "label": "理解",
      "prompt": "真正被理解的感觉会是什么样的？",
      "hints": [
        "我希望人们都知道这一点……",
        "我内心真正的感受是……",
        "没人看到我……"
      ]
    },
    "Stability": {
      "label": "稳定",
      "prompt": "你现在觉得生活中稳定是什么样的？",
      "hints": [
        "我需要一些能让我感到……的东西。",
        "能让我脚踏实地的，是……",
        "稳定意味着……"
      ]
    },
    "Honesty": {
      "label": "诚实",
      "prompt": "在你的情况下，怎样才算更诚实？",
      "hints": [
        "我必须面对的真相是……",
        "我想坦诚地说……",
        "实际情况是……"
      ]
    },
    "Respect": {
      "label": "尊重",
      "prompt": "你现在认为尊重是什么样的？",
      "hints": [
        "我应该受到应有的待遇……",
        "尊重应该体现在……",
        "我需要人们……"
      ]
    },
    "Clarity about relationship": {
      "label": "对关系的清晰认识",
      "prompt": "哪种类型的清晰说明对您最有帮助？",
      "hints": [
        "我需要知道是否……",
        "让我困惑的是……",
        "我希望我们能明确一点……"
      ]
    },
    "default": {
      "prompt": "实际情况会是怎样的？",
      "hints": [
        "我首先想到的是……",
        "我现在感觉……",
        "如果我对自己诚实的话……"
      ]
    }
  },
