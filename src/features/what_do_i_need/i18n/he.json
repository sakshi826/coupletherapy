        "הייתי מנצלת את הזמן הזה כדי...",
        "החלל יאפשר לי...",
        "אני צריך מקום ל..."
      ]
    },
    "Clear communication": {
      "label": "תקשורת ברורה",
      "prompt": "איך תיראה תקשורת ברורה יותר עבורך?",
      "hints": [
        "הלוואי ויכולתי לומר...",
        "אם הם באמת היו מקשיבים, הייתי אומר להם...",
        "התקשורת מרגישה קשה כש..."
      ]
    },
    "Reassurance": {
      "label": "הרגעה",
      "prompt": "איזה סוג של הרגעה ירגיש משמעותי?",
      "hints": [
        "אני צריך לשמוע את זה...",
        "זה היה מרגיע אותי לדעת...",
        "אני כל הזמן דואג ש..."
      ]
    },
    "Understanding": {
      "label": "הבנה",
      "prompt": "איך תיראה תחושת הבנה אמיתית?",
      "hints": [
        "הלוואי שאנשים ידעו את זה...",
        "מה שאני באמת מרגיש זה...",
        "אף אחד לא רואה שאני..."
      ]
    },
    "Stability": {
      "label": "יציבות",
      "prompt": "איך תרגיש יציבות בחיים שלך כרגע?",
      "hints": [
        "אני צריך שהדברים ירגישו...",
        "מה שיכול לקרקע אותי זה...",
        "יציבות משמעות..."
      ]
    },
    "Honesty": {
      "label": "כנות",
      "prompt": "איך ייראה יותר כנות במצב שלך?",
      "hints": [
        "האמת שאני צריך להתמודד איתה היא...",
        "אני רוצה להיות כנה לגבי...",
        "מה שבאמת קורה זה..."
      ]
    },
    "Respect": {
      "label": "כבוד",
      "prompt": "איך נראה כבוד עבורך כרגע?",
      "hints": [
        "אני ראוי שיטפלו בי...",
        "כבוד היה נראה כמו...",
        "אני צריך אנשים ש..."
      ]
    },
    "Clarity about relationship": {
      "label": "בהירות לגבי מערכות יחסים",
      "prompt": "איזה בהירות תעזור לך הכי הרבה?",
      "hints": [
        "אני צריך לדעת אם...",
        "מה שמבלבל אותי זה...",
        "אני רוצה שנהיה ברורים לגבי..."
      ]
    },
    "default": {
      "prompt": "איך זה היה נראה במצב אמיתי?",
